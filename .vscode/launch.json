{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Запустить КСП «СТЫК»",
            "type": "go",
            "request": "launch",
            "mode": "exec",
            "preLaunchTask": "wails_debug_build",
            "env": {},
            "args": [
                "-vv"
            ],
            "linux": {
                "program": "${workspaceFolder}/build/bin/styk"
            },
            "windows": {
                "program": "${workspaceFolder}/build/bin/styk.exe"
            }
        },
        {
            "name": "Отладить Web-часть",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:34115",
            "webRoot": "${workspaceFolder}"
        }
    ]
}
